# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here
PRIMARY_MODEL=llama-3.3-70b-versatile
CONTEXT_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2

# Set to "context" to route the LangGraph agent loop through CONTEXT_MODEL
# instead of PRIMARY_MODEL.
# AGENT_MODEL=primary

# --- Database ---

# SQLite (optional local development)
# DATABASE_URL=sqlite+aiosqlite:///./debrief_dev.db

# PostgreSQL
# DATABASE_URL=postgresql+asyncpg://debrief:debrief@localhost:5432/debrief

# --- App ---
ENV=development
FRONTEND_ORIGIN=http://localhost:5173